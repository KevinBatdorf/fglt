{
	"name": "fglt-desktop",
	"version": "0.1.0",
	"description": "Find a Game Like That — Electrobun desktop UI over a multi-store library API.",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:icons": "bun run scripts/build-icons.ts",
		"build:backend": "bun run scripts/bundle-backend.ts",
		"build:assets": "bun run build:backend && cp ../../docker-compose.consumer.yml assets/docker-compose.consumer.yml",
		"patch:electrobun": "bun run scripts/patch-electrobun.ts",
		"build": "bun run patch:electrobun && bun run build:icons && bun run build:assets && vite build && electrobun build --env=stable",
		"build:installer": "bun run scripts/package-windows.ts",
		"stamp:version": "bun run scripts/stamp-version.ts"
	},
	"dependencies": {
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource-variable/inter": "^5.2.8",
		"electrobun": "^1.0.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"png-to-ico": "^3.0.1",
		"postcss": "^8.4.49",
		"rcedit": "^4.0.1",
		"sharp": "^0.34.5",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
