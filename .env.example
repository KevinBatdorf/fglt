# =====================================================================
# Container config — used by docker-compose. These don't have a UI
# equivalent because they affect the stack itself, not user data.
# =====================================================================

# Port the Hono API listens on (host -> container)
PORT=3110

# Postgres host port (container is always 5432). Default 5532 to avoid clashing with anna's 5432.
POSTGRES_PORT=5532

# Database connection used by the API + cron containers. Override only
# if you're pointing at a Postgres other than the bundled one.
# DATABASE_URL=postgres://seg:seg@postgres:5432/seg


# =====================================================================
# User-facing config — the desktop app's Settings → Configuration page
# writes these to the `app_settings` table. ANY value set here in .env
# WINS over the DB row, which is convenient for dev. Production /
# end-user installs should leave these blank and let the UI manage them.
# =====================================================================

# --- Steam Web API (REQUIRED — library sync needs both) ---
# Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Your 64-bit SteamID. Find it at https://steamid.io/ (paste your profile URL)
STEAM_ID=

# --- AI provider (any OpenAI-compatible endpoint) ---
# Used for embeddings (search) and the /vibes generator. Configure ANY
# OpenAI-compatible endpoint:
#   Ollama: AI_BASE_URL=http://host.docker.internal:11434/v1
#   OpenAI: AI_BASE_URL=https://api.openai.com/v1   + AI_API_KEY=sk-...
#   Groq:   AI_BASE_URL=https://api.groq.com/openai/v1 + AI_API_KEY=gsk_...
#   Together: AI_BASE_URL=https://api.together.xyz/v1 + AI_API_KEY=...
# If AI_BASE_URL is empty and OLLAMA_URL is set, the helper derives
# `${OLLAMA_URL}/v1` automatically.
AI_BASE_URL=
AI_API_KEY=
AI_PROVIDER_NAME=ollama
AI_CHAT_MODEL=qwen3:14b
AI_EMBED_MODEL=nomic-embed-text

# Legacy Ollama-specific env. Still works as a fallback when AI_BASE_URL
# is empty; the AI helper auto-derives the OpenAI-compat URL.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen3:14b

# --- YouTube Data API v3 (for trailers / walkthroughs / let's-plays) ---
# Get a key: https://console.cloud.google.com → New project → Enable
# "YouTube Data API v3" → Credentials → Create API key.
# Free tier is 10,000 units/day; each search costs 100 units (~100 games/day).
# Sync no-ops if this is empty.
YOUTUBE_API_KEY=

# --- OpenCritic (aggregated critic scores) ---
# OpenCritic moved their public API behind RapidAPI. To populate critic
# scores in the desktop app:
#   1. Go to https://rapidapi.com/opencritic-opencritic-default/api/opencritic-api
#   2. Sign in (GitHub / Google / email) and click Subscribe → free Basic plan.
#   3. Copy your X-RapidAPI-Key (shown on any code snippet on the same page).
#   4. Paste it here and `docker compose up -d api enricher`.
# Free tier ≈ 25 lookups/day. Cron caps at 20 (see OPENCRITIC_DAILY_BUDGET)
# so ~5 lookups stay free for manual /refresh from the desktop. Leave empty
# to disable OpenCritic entirely (UI shows a clear "needs key" placeholder).
OPENCRITIC_API_KEY=
OPENCRITIC_DAILY_BUDGET=20

# --- HowLongToBeat (game completion times) ---
# No API key — public site scraping. HLTB doesn't publish a rate limit but
# they do anti-bot (Fastly edge blocks aggressive callers). 80 calls/day
# is a conservative floor that leaves headroom for manual /refresh from
# the desktop. The cron container is short-lived so the budget effectively
# resets every 15 min tick. The API container shares a counter, so a long
# session of manual refreshes will eventually trip the limit.
HLTB_DAILY_BUDGET=80


# =====================================================================
# Cron schedules — only honored by the cron containers, not surfaced in
# the UI. Change here + `docker compose up -d` to re-roll.
# =====================================================================

# Refresh owned games list (default: daily at 06:00)
SYNC_CRON=0 6 * * *
# Enrichment + embedding pass (default: every 15 minutes)
ENRICH_CRON=*/15 * * * *
# Max games per enrichment batch
ENRICH_BATCH=50
# YouTube sync runs once per day shortly after Google's quota reset (00:00 PT
# = ~07:00-08:00 UTC). 06:30 UTC gives a safe margin.
YOUTUBE_CRON=30 6 * * *
# Hard cap on games processed per run. Default 90 (out of the ~100/day
# floor allowed by free quota) so ~10 slots stay free for manual fetches.
YOUTUBE_BATCH=90
# Videos saved per game.
YOUTUBE_PER_GAME=10
# Delay between game searches (ms).
YOUTUBE_DELAY_MS=300
# SteamSpy refresher — daily at 05:00 UTC. Skips games refreshed within
# REFRESH_DAYS. SteamSpy tolerates ~1 req/sec.
STEAMSPY_CRON=0 5 * * *
STEAMSPY_BATCH=500
STEAMSPY_DELAY_MS=1100
STEAMSPY_REFRESH_DAYS=7
